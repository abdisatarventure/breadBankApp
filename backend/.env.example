# Copy to backend/.env and fill in real values. Never commit the real .env.

# Anthropic API key used for AI categorization, summaries, and chat.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SQL Server connection. Defaults connect to localhost\SQLEXPRESS with SQL auth.
DB_SERVER=localhost
DB_INSTANCE=SQLEXPRESS               # named instance; set empty for a default instance
DB_NAME=breadbank
DB_USER=breadbank_user
DB_PASSWORD=your-db-password-here   # required — the app refuses to start without it

# API server port.
PORT=3001

# Comma-separated list of allowed CORS origins (frontend URLs).
CORS_ORIGIN=http://localhost:9000

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Plaid (bank linking). Get these from dashboard.plaid.com → Developers → Keys.
# Use PLAID_ENV=sandbox with the Sandbox secret while developing; switch to
# production + the Production secret once Plaid grants production access.
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox

# AES-256 key for encrypting Plaid access tokens at rest. 32 bytes as 64 hex
# chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLAID_ENC_KEY=your-64-char-hex-key
