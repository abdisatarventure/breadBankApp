# Copy to backend/.env and fill in real values. Never commit the real .env.

# Anthropic API key used for AI categorization, summaries, and chat.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SQL Server (connects to localhost\SQLEXPRESS by default — see src/config/db.ts).
DB_NAME=breadbank
DB_USER=breadbank_user
DB_PASSWORD=your-db-password-here   # required — the app refuses to start without it

# API server port.
PORT=3000

# Comma-separated list of allowed CORS origins (frontend URLs).
CORS_ORIGIN=http://localhost:9000

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
